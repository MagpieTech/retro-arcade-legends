---
import { ViewTransitions } from 'astro:transitions';
import '../../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Retro Arcade Legends',
  description = 'A tradable card explorer of legendary characters, machines, and moments from arcade gaming history (1970s–1990s).',
} = Astro.props;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/cards', label: 'All Cards' },
  { href: '/compare', label: 'Compare' },
  { href: '/about', label: 'About' },
];

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | Retro Arcade Legends</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <ViewTransitions />
  </head>
  <body class="bg-[var(--bg-dark)] text-[var(--text-primary)] font-body min-h-screen flex flex-col">
    <header class="border-b border-white/10 bg-[var(--bg-card)]/80 backdrop-blur-sm sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <a href="/" class="font-arcade text-[var(--arcade-gold)] text-xs leading-relaxed hover:text-white transition-colors">
            ARCADE<br/>LEGENDS
          </a>
          <nav class="hidden sm:flex items-center gap-6">
            {navLinks.map(({ href, label }) => (
              <a
                href={href}
                class:list={[
                  'font-body text-sm font-medium transition-colors',
                  currentPath === href
                    ? 'text-[var(--arcade-gold)]'
                    : 'text-[var(--text-muted)] hover:text-[var(--text-primary)]',
                ]}
              >
                {label}
              </a>
            ))}
          </nav>
          <!-- Mobile nav -->
          <nav class="flex sm:hidden items-center gap-4">
            {navLinks.map(({ href, label }) => (
              <a
                href={href}
                class:list={[
                  'text-xs font-medium transition-colors',
                  currentPath === href
                    ? 'text-[var(--arcade-gold)]'
                    : 'text-[var(--text-muted)] hover:text-[var(--text-primary)]',
                ]}
              >
                {label}
              </a>
            ))}
          </nav>
        </div>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-white/10 bg-[var(--bg-card)]/40 mt-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
          <p class="font-arcade text-[var(--arcade-gold)] text-[10px]">RETRO ARCADE LEGENDS</p>
          <p class="text-[var(--text-muted)] text-xs">30 cards · 3 eras · insert coin to continue</p>
        </div>
      </div>
    </footer>
  </body>
</html>
