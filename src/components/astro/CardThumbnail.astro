---
import RarityBadge from './RarityBadge.astro';
import EraTag from './EraTag.astro';

interface Props {
  card: {
    id: string;
    name: string;
    type: 'character' | 'machine' | 'moment';
    era: '1970s' | '1980s' | '1990s';
    rarity: 'common' | 'rare' | 'legendary';
    influence: number;
    quarters: number;
    legacy: number;
    description: string;
    quote: string;
    colour: string;
    tags: string[];
    studio: string;
    debut: number;
  };
}

const { card } = Astro.props;

const typeColours = {
  character: 'var(--arcade-teal)',
  machine:   'var(--arcade-purple)',
  moment:    'var(--arcade-green)',
};
---

<a
  href={`/cards/${card.id}`}
  class:list={[
    'group block rounded-xl border border-white/10 bg-[var(--bg-card)] overflow-hidden',
    'hover:border-white/30 hover:shadow-lg transition-all duration-200',
    card.rarity === 'legendary' ? 'card--legendary' : '',
  ]}
  style={`--card-colour: ${card.colour}`}
>
  <!-- Colour accent strip -->
  <div class="h-1.5 w-full" style={`background-color: ${card.colour}`} />

  <div class="p-4 space-y-3 relative z-10">
    <!-- Header row -->
    <div class="flex items-start justify-between gap-2">
      <h2 class="font-arcade text-[11px] leading-relaxed text-[var(--text-primary)] group-hover:text-[var(--arcade-gold)] transition-colors line-clamp-2">
        {card.name}
      </h2>
      <span
        class="shrink-0 text-[9px] font-arcade uppercase px-1.5 py-0.5 rounded border"
        style={`color: ${typeColours[card.type]}; border-color: ${typeColours[card.type]}40; background-color: ${typeColours[card.type]}18`}
      >
        {card.type}
      </span>
    </div>

    <!-- Badges -->
    <div class="flex items-center gap-1.5 flex-wrap">
      <RarityBadge rarity={card.rarity} size="sm" />
      <EraTag era={card.era} size="sm" />
    </div>

    <!-- Quote -->
    <p class="text-[var(--text-muted)] text-xs italic line-clamp-1">"{card.quote}"</p>

    <!-- Stats row -->
    <div class="grid grid-cols-3 gap-2 pt-1 border-t border-white/10">
      {[
        { label: 'INF', value: card.influence },
        { label: 'QTR', value: card.quarters },
        { label: 'LGY', value: card.legacy },
      ].map(({ label, value }) => (
        <div class="text-center">
          <div class="font-mono text-sm font-bold" style={`color: ${card.colour}`}>{value}</div>
          <div class="text-[9px] text-[var(--text-muted)] uppercase tracking-wider">{label}</div>
        </div>
      ))}
    </div>

    <!-- Studio & debut -->
    <div class="text-[10px] text-[var(--text-muted)]">{card.studio} · {card.debut}</div>
  </div>
</a>
