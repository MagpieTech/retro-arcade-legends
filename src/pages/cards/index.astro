---
import Layout from '../../components/astro/Layout.astro';
import CardBrowser from '../../components/islands/CardBrowser';
import FavouritesDrawer from '../../components/islands/FavouritesDrawer';
import cards from '../../data/cards.json';
---

<Layout title="All Cards">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 space-y-8">
    <div class="flex items-start justify-between gap-4">
      <div class="space-y-2">
        <h1 class="font-arcade text-xl text-[var(--text-primary)]">All Cards</h1>
        <p class="text-[var(--text-muted)]">{cards.length} cards from the arcade legends collection.</p>
      </div>
      <FavouritesDrawer client:idle cards={cards} />
    </div>

    <CardBrowser client:load cards={cards} />
  </div>
</Layout>
