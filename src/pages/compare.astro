---
import Layout from '../components/astro/Layout.astro';
import CompareWidget from '../components/islands/CompareWidget';
import cards from '../data/cards.json';
---

<Layout title="Compare Cards">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12 space-y-8">
    <div class="space-y-2">
      <h1 class="font-arcade text-xl text-[var(--text-primary)]">Compare</h1>
      <p class="text-[var(--text-muted)]">Pick two cards to compare their stats head-to-head.</p>
    </div>

    <CompareWidget client:visible cards={cards} />

    <noscript>
      <p class="text-[var(--text-muted)] text-sm border border-white/10 rounded-lg p-4">
        JavaScript is required to use the compare feature. Browse individual cards at
        <a href="/cards" class="text-[var(--arcade-gold)] underline">/cards</a>.
      </p>
    </noscript>
  </div>
</Layout>
